COSYVOICE_SPK_ID=中文女
COSYVOICE_INSTRUCT_TEXT=用自然、清晰、亲切的语气说话。
COSYVOICE_SPEED=1.25
COSYVOICE_TEXT_FRONTEND=0
COSYVOICE_LOAD_JIT=0
COSYVOICE_LOAD_TRT=0
