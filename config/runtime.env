# 首次启动会复制到 data/config/runtime.env；运行时请改 data 里的副本。
# 当前语音栈：ReSpeaker + SenseVoice ASR + EdgeTTS。

## 日志

CHAT2ME_LOG_LEVEL=info
CHAT2ME_CONSOLE_LOG_LEVEL=info

## LLM

LLM_ENGINE=ollama

# 在线 LLM：LLM_ENGINE=online 时使用
LLM_ONLINE_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=128
LLM_MAX_TOKENS_FIELD=max_tokens
LLM_TIMEOUT_SECONDS=180
LLM_CONNECT_TIMEOUT_SECONDS=5
EMPTY_ANSWER_RESPONSE=抱歉，我还不太确定该如何回答这个问题。

# 本地 Ollama：用于本地聊天、在线失败回落
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_THREAD=8
OLLAMA_KEEP_ALIVE=30m

# 本地意图分类
INTENT_CLASSIFIER_ENABLED=1
INTENT_CONFIDENCE_THRESHOLD=0.70
INTENT_MODEL=qwen3:0.6b
INTENT_MAX_TOKENS=48
INTENT_NUM_CTX=1024
INTENT_TEMPERATURE=0
INTENT_TIMEOUT_SECONDS=15

## 音频设备

AUDIO_INPUT_DEVICE=ReSpeaker
AUDIO_INPUT_CHANNELS=6
AUDIO_INPUT_CHANNEL_INDEX=0
AUDIO_OUTPUT_DEVICE=pulse
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=0.1

## ReSpeaker

RESPEAKER_ENABLED=1
RESPEAKER_USB_VENDOR_ID=0x2886
RESPEAKER_USB_PRODUCT_ID=0x0018
RESPEAKER_RECONNECT_SECONDS=5
RESPEAKER_TUNING_ENABLED=1
RESPEAKER_HPF_MODE=2
RESPEAKER_AGC_ENABLED=1
RESPEAKER_AGC_MAX_GAIN=63.1
RESPEAKER_AGC_DESIRED_LEVEL=0.012
RESPEAKER_AGC_TIME_SECONDS=0.4
RESPEAKER_STATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_NONSTATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_STATIONARY_NOISE_SUPPRESSION_LEVEL=2.2
RESPEAKER_NONSTATIONARY_NOISE_SUPPRESSION_LEVEL=2.4
RESPEAKER_STATIONARY_NOISE_SUPPRESSION_FLOOR=0.10
RESPEAKER_NONSTATIONARY_NOISE_SUPPRESSION_FLOOR=0.16
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION_LEVEL=2.6
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION_LEVEL=2.8
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION_FLOOR=0.08
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION_FLOOR=0.12
RESPEAKER_VAD_THRESHOLD_DB=2.0
RESPEAKER_VAD_GATE_ENABLED=1
RESPEAKER_ECHO_SUPPRESSION_ENABLED=1
RESPEAKER_ECHO_SUPPRESSION_LEVEL=2.0
RESPEAKER_ECHO_TAIL_SUPPRESSION_LEVEL=2.0
RESPEAKER_NONLINEAR_AEC_ENABLED=1
RESPEAKER_NONLINEAR_AEC_MODE=2
RESPEAKER_NONLINEAR_ECHO_SUPPRESSION_LEVEL=3.5
RESPEAKER_TRANSIENT_ECHO_SUPPRESSION_ENABLED=1
RESPEAKER_DOA_FRONT_OFFSET_DEGREES=0
RESPEAKER_DOA_CLOCKWISE=1

## 状态屏与 Relay

DISPLAY_SERIAL_PORT=auto
DISPLAY_SERIAL_CANDIDATES=/host-dev/serial/by-id/usb-Espressif_USB_JTAG_serial_debug_unit_*-if00
DISPLAY_SERIAL_BAUD=115200
DISPLAY_SYNC_SECONDS=1.0
DISPLAY_TEXT_MAX_CHARS=80
DISPLAY_SERIAL_RETRY_SECONDS=5
RELAY_POLL_SECONDS=0.2
RELAY_SOURCE_TIMEOUT_SECONDS=1.0

## 唤醒与 ASR

VOICE_ASR_ENGINE=sensevoice
VOICE_ASR_MODEL=sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2025-09-09
WAKE_WORDS=小江同学,小江
KWS_KEYWORDS_SCORE=2.0
KWS_KEYWORDS_THRESHOLD=0.10
KWS_THREADS=1
ASR_THREADS=2
SENSEVOICE_LANGUAGE=auto
SENSEVOICE_USE_ITN=1
ASR_HOMOPHONE_REPLACER_ENABLED=1
ASR_HOMOPHONE_GENERATE_ON_START=1
ASR_NOISE_GATE_ENABLED=1
ASR_NOISE_CALIBRATION_SECONDS=0.2
ASR_NOISE_GATE_PERCENTILE=50
ASR_NOISE_GATE_RATIO=0.4
ASR_NOISE_GATE_OFFSET=0.002
ASR_PREROLL_SECONDS=0.5

## 对话流程

CORE_REQUEST_TIMEOUT_SECONDS=30
CORE_UNAVAILABLE_RESPONSE=对话服务暂时不可用
DIRECTION_CHANGE_POLL_SECONDS=0.5
COMMAND_TIMEOUT_SECONDS=10
COMMAND_MIN_SECONDS=1.2
COMMAND_LEADING_SILENCE_SECONDS=3
COMMAND_INITIAL_GRACE_SECONDS=0.8
SPEECH_RMS_THRESHOLD=0.0025
PRE_BEEP_DRAIN_SECONDS=0.05
POST_BEEP_DRAIN_SECONDS=0.05
POST_RESPONSE_DRAIN_SECONDS=0.15
SPEECH_WAIT_LOG_SECONDS=30
SPEECH_WAIT_POLL_SECONDS=1
WAKE_RESPONSE=我在
SESSION_IDLE_RESPONSE=
SESSION_END_RESPONSE=好的，我先退下了
SESSION_END_PHRASES=退出,结束,不用了,没事了,再见,拜拜,回到待机,退下,退下吧,你走吧,走吧,下去吧,可以了,先这样
MAX_SESSION_TURNS=8

## TTS

VOICE_TTS_ENGINE=online
VOICE_TTS_MODEL=edge-tts
VOICE_TTS_DEVICE=auto
TTS_PLAYER_TIMEOUT_SECONDS=30
SPEECH_TTS_MAX_CHARS=70
TTS_CACHE_ENABLED=1
TTS_CACHE_MAX_ITEMS=32
TTS_CACHE_MAX_BYTES=2097152
TTS_PLAYBACK_MODE=buffered
TTS_PREBUFFER_SECONDS=0.0
TTS_PLAYBACK_RETRY_SECONDS=3
TTS_WARMUP_TEXTS=
TTS_SERVICE_CONNECT_TIMEOUT_SECONDS=3
TTS_SERVICE_READ_TIMEOUT_SECONDS=35
TTS_REACHABILITY_INTERVAL_SECONDS=5
TTS_REACHABILITY_TIMEOUT_SECONDS=3
TTS_ONLINE_SYNTHESIS_TIMEOUT_SECONDS=8
TTS_ONLINE_FAILURE_COOLDOWN_SECONDS=30
TTS_ONLINE_RECENT_SUCCESS_GRACE_SECONDS=30
TTS_LOCAL_SYNTHESIS_TIMEOUT_SECONDS=20
TTS_LOCAL_LOCK_TIMEOUT_SECONDS=5
TTS_NORMALIZE_ENABLED=1
TTS_TARGET_RMS_DBFS=-22.0
TTS_PEAK_LIMIT_DBFS=-2.0
TTS_NORMALIZE_ACTIVE_FLOOR_DBFS=-45.0
TTS_NORMALIZE_MIN_GAIN=0.25
TTS_NORMALIZE_MAX_GAIN=6.0

## MeloTTS

MELOTTS_SPEED=1.0
MELOTTS_SDP_RATIO=0.2
MELOTTS_NOISE_SCALE=0.6
MELOTTS_NOISE_SCALE_W=0.8
MELOTTS_DISABLE_BERT=1

## EdgeTTS

EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_PROXY=
EDGE_TTS_SAMPLE_RATE=24000
EDGE_TTS_CONNECT_TIMEOUT_SECONDS=3
EDGE_TTS_RECEIVE_TIMEOUT_SECONDS=8

## 调试

LOCK_WAIT_LOG_SECONDS=30
MODEL_DOWNLOAD_RETRIES=10
