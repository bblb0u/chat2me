# 首次启动会复制到 data/config/runtime.env；运行时请改 data 里的副本。
# 全量可选项和说明见仓库根目录 .env.example。

## LLM 路由

LLM_PROVIDER=ollama
LLM_MODEL=
LLM_BASE_URL=
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_REACHABILITY_PATH=/models
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=128
LLM_MAX_TOKENS_FIELD=max_tokens
LLM_TIMEOUT_SECONDS=180
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_REACHABILITY_INTERVAL_SECONDS=5
LLM_REACHABILITY_TIMEOUT_SECONDS=1.5
LLM_ROUTE_CACHE_INTERVAL_SECONDS=2
NETWORK_UNAVAILABLE_RESPONSE=网络连接不可用
EMPTY_ANSWER_RESPONSE=我暂时没有生成有效回答。
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_THREAD=8
CORE_LLM_URL=http://chat2me-llm:8082/chat
CORE_LLM_REACHABILITY_URL=http://chat2me-llm:8082/llm/reachability
CORE_LLM_HEALTH_URL=http://chat2me-llm:8082/health
CORE_LLM_TIMEOUT_SECONDS=180
CORE_LLM_REACHABILITY_TIMEOUT_SECONDS=2
ASR_ROUTE_CACHE_INTERVAL_SECONDS=2
TTS_ROUTE_CACHE_INTERVAL_SECONDS=2

## 语音模型选择

VOICE_ASR_ENGINE=sensevoice
VOICE_ASR_MODEL=SenseVoiceSmall
VOICE_ASR_FALLBACK_ENGINE=sensevoice
VOICE_ASR_FALLBACK_MODEL=SenseVoiceSmall
VOICE_ASR_DEVICE=auto
VOICE_TTS_ENGINE=melotts
VOICE_TTS_MODEL=vits-melo-tts-zh_en
VOICE_TTS_FALLBACK_ENGINE=melotts
VOICE_TTS_FALLBACK_MODEL=vits-melo-tts-zh_en
VOICE_TTS_DEVICE=auto
ASR_SERVICE_URL=http://chat2me-asr:8092/asr/transcribe
ASR_REACHABILITY_URL=http://chat2me-asr:8092/asr/reachability
TTS_SERVICE_URL=http://chat2me-tts:8093/tts/speak
TTS_REACHABILITY_URL=http://chat2me-tts:8093/tts/reachability

## 音频设备

AUDIO_INPUT_DEVICE=ReSpeaker
AUDIO_INPUT_CHANNELS=1
AUDIO_INPUT_CHANNEL_INDEX=0
AUDIO_OUTPUT_DEVICE=plughw:CARD=ArrayUAC10,DEV=0
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=0.1

## ReSpeaker

RESPEAKER_ENABLED=1
RESPEAKER_USB_VENDOR_ID=0x2886
RESPEAKER_USB_PRODUCT_ID=0x0018
RESPEAKER_TUNING_ENABLED=1
RESPEAKER_AGC_ENABLED=1
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION=1
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION_LEVEL=2.0
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION_LEVEL=2.0
RESPEAKER_VAD_THRESHOLD_DB=3.5
RESPEAKER_ECHO_SUPPRESSION_ENABLED=0
RESPEAKER_NONLINEAR_AEC_ENABLED=0
RESPEAKER_DOA_FRONT_OFFSET_DEGREES=0
RESPEAKER_DOA_CLOCKWISE=1

## 状态屏

DISPLAY_SERIAL_PORT=auto
DISPLAY_SERIAL_CANDIDATES=/host-dev/serial/by-id/usb-Espressif_USB_JTAG_serial_debug_unit_*-if00
DISPLAY_SERIAL_BAUD=115200
DISPLAY_SYNC_SECONDS=1.0
DISPLAY_TEXT_MAX_CHARS=80
DISPLAY_SERIAL_RETRY_SECONDS=5

## 唤醒与 ASR

WAKE_WORDS=小江同学,小江
KWS_KEYWORDS_SCORE=1.5
KWS_KEYWORDS_THRESHOLD=0.25
KWS_THREADS=1
VOICE_KWS_PROVIDER=auto
ASR_THREADS=2
ASR_MODEL_PRECISION=fp32
ASR_DECODING_METHOD=modified_beam_search
ASR_MAX_ACTIVE_PATHS=8
ASR_MODELING_UNIT=cjkchar+bpe
ASR_HOTWORDS_SCORE=2.0

## Online ASR

ONLINE_ASR_BASE_URL=https://api.openai.com/v1
ONLINE_ASR_REACHABILITY_PATH=/models
ONLINE_ASR_TRANSCRIPTIONS_PATH=/audio/transcriptions
ONLINE_ASR_API_KEY=
ONLINE_ASR_LANGUAGE=zh
ONLINE_ASR_PROMPT=
ONLINE_ASR_RESPONSE_FORMAT=json
ONLINE_ASR_TIMEOUT_SECONDS=45
ONLINE_ASR_MIN_AUDIO_SECONDS=0.8
ONLINE_ASR_SILENCE_SECONDS=0.8
ONLINE_ASR_RMS_THRESHOLD=0.006
ASR_REACHABILITY_INTERVAL_SECONDS=5
ASR_REACHABILITY_TIMEOUT_SECONDS=1.5

## 对话流程

GATEWAY_REQUEST_TIMEOUT_SECONDS=30
GATEWAY_UNAVAILABLE_RESPONSE=对话服务暂时不可用
GATEWAY_URL=http://chat2me-core:8080/chat
GATEWAY_REACHABILITY_URL=http://chat2me-core:8080/llm/reachability
RELAY_SOURCE_URL=http://chat2me-speech:8090/state
RELAY_POLL_SECONDS=0.2
RELAY_SOURCE_TIMEOUT_SECONDS=1.0
SPEECH_STATE_URL=http://chat2me-speech:8090/state
DIRECTION_CHANGE_POLL_SECONDS=0.5
CORE_URL=http://chat2me-core:8080/chat
CORE_REACHABILITY_URL=http://chat2me-core:8080/llm/reachability
CORE_REQUEST_TIMEOUT_SECONDS=30
CORE_UNAVAILABLE_RESPONSE=对话服务暂时不可用
COMMAND_TIMEOUT_SECONDS=10
COMMAND_MIN_SECONDS=1.2
COMMAND_LEADING_SILENCE_SECONDS=3
COMMAND_INITIAL_GRACE_SECONDS=0.8
SPEECH_RMS_THRESHOLD=0.006
ASR_NOISE_GATE_ENABLED=1
ASR_NOISE_CALIBRATION_SECONDS=0.2
ASR_NOISE_GATE_PERCENTILE=30
ASR_NOISE_GATE_RATIO=0.3
ASR_NOISE_GATE_OFFSET=0.006
ASR_PREROLL_SECONDS=0.3
ASR_WARMUP_SECONDS=10
ASR_WARMUP_WAV_PATH=/app/assets/asr_warmup_16k.wav
ASR_RULE1_MIN_TRAILING_SILENCE=1.2
ASR_RULE2_MIN_TRAILING_SILENCE=0.8
ASR_RULE3_MIN_UTTERANCE_LENGTH=8
PRE_BEEP_DRAIN_SECONDS=0.05
POST_BEEP_DRAIN_SECONDS=0.05
POST_RESPONSE_DRAIN_SECONDS=0.5
SPEECH_WAIT_LOG_SECONDS=30
SPEECH_WAIT_POLL_SECONDS=1
WAKE_RESPONSE=我在
SESSION_IDLE_RESPONSE=
SESSION_END_RESPONSE=好的，我先退下了
SESSION_END_PHRASES=退出,结束,不用了,没事了,再见,拜拜,回到待机,退下,退下吧,你走吧,走吧,下去吧,可以了,先这样
MAX_SESSION_TURNS=8

## TTS 通用

TTS_PLAYER_TIMEOUT_SECONDS=30
SPEECH_TTS_MAX_CHARS=70
TTS_CACHE_ENABLED=1
TTS_CACHE_MAX_ITEMS=32
TTS_CACHE_MAX_BYTES=2097152
TTS_PLAYBACK_MODE=buffered
TTS_PREBUFFER_SECONDS=0.0
TTS_WARMUP_TEXTS=

## Piper

PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=0.9
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.8

## MeloTTS

MELOTTS_THREADS=4
MELOTTS_PROVIDER=auto
MELOTTS_SPEAKER=0
MELOTTS_SPEED=1.0
MELOTTS_LENGTH_SCALE=1.0
MELOTTS_NOISE_SCALE=0.667
MELOTTS_NOISE_W_SCALE=0.8
MELOTTS_SILENCE_SCALE=0.2
MELOTTS_RULE_FSTS=phone.fst,date.fst,number.fst,new_heteronym.fst

## Sherpa ONNX TTS

SHERPA_TTS_THREADS=2
SHERPA_TTS_PROVIDER=auto
SHERPA_TTS_SPEED=1.0
SHERPA_TTS_LENGTH_SCALE=1.0
SHERPA_TTS_NOISE_SCALE=1.0
SHERPA_TTS_SILENCE_SCALE=0.2
SHERPA_TTS_RULE_FSTS=phone-zh.fst,date-zh.fst,number-zh.fst

## SenseVoice ASR

SENSEVOICE_LANGUAGE=auto
SENSEVOICE_ITN_MIN_SPEECH_MS=2000
SENSEVOICE_VAD_START_THRESHOLD=0.7
SENSEVOICE_VAD_END_THRESHOLD=0.3
SENSEVOICE_VAD_START_PERSISTENCE_MS=100
SENSEVOICE_VAD_END_PERSISTENCE_MS=500
SENSEVOICE_VAD_START_PADDING_MS=100
SENSEVOICE_ASR_TRIGGER_BUFFER_MS=1000
SENSEVOICE_ASR_UPDATE_INTERVAL_MS=500

## F5-TTS

F5_TTS_REF_AUDIO=
F5_TTS_REF_TEXT=对，这就是我，万人敬仰的太乙真人。
F5_TTS_NFE_STEP=4
