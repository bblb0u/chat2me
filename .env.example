# Chat2M runtime.env 配置参考
# 实际运行请修改 /opt/chat2m/data/config/runtime.env。
# 这里列的是建议对外开放的运行参数；容器内部路径和服务地址不作为用户配置项。

# 大模型路由。ollama/local 表示本地 Ollama；其他任意值都表示在线 OpenAI-compatible 接口。
# 例如 openai、deepseek、remote、自建服务名都可以，真正调用地址只由 LLM_BASE_URL 决定。
LLM_PROVIDER=ollama

# 在线对话模型名。本地 Ollama 会话使用 OLLAMA_MODEL；在线会话使用这个值。
# 示例：gpt-5-mini、deepseek-chat、qwen2.5:7b-instruct 或自建服务端实际模型名。
LLM_MODEL=

# 在线接口地址。本地 Ollama 模式留空。
# OpenAI 示例：https://api.openai.com/v1；DeepSeek 示例：https://api.deepseek.com；
# 自建服务示例：http://192.168.1.10:8000/v1。
# 如果网关地址本身不带 /v1，例如 https://sub2api.canghai.org，
# 就把下面两个 path 配成 /v1/chat/completions 和 /v1/models。
LLM_BASE_URL=

# 在线聊天接口路径。OpenAI-compatible 默认是 /chat/completions，也可配成 /v1/chat/completions 或 /v1/responses。
LLM_CHAT_COMPLETIONS_PATH=/chat/completions

# 在线可达性探测接口路径。OpenAI-compatible 默认是 /models，也可配成 /v1/models。
LLM_REACHABILITY_PATH=/models

# 远程 OpenAI-compatible API Key。本地 Ollama 模式留空。
LLM_API_KEY=

# 生成温度。越低越稳定，越高越发散。
LLM_TEMPERATURE=0.2

# nucleus sampling 参数。
LLM_TOP_P=0.9

# 单次回答最大 token 数，语音播报建议不要太大。
LLM_MAX_TOKENS=128

# 在线接口最大 token 字段名。常见 Chat Completions 服务使用 max_tokens；Responses API 通常使用 max_output_tokens。
LLM_MAX_TOKENS_FIELD=max_tokens

# 大模型请求总读取超时秒数。
LLM_TIMEOUT_SECONDS=180

# 大模型连接超时秒数。
LLM_CONNECT_TIMEOUT_SECONDS=5

# 远程大模型后台可达性探测间隔秒数。唤醒后只读取缓存，不临时探测。
LLM_REACHABILITY_INTERVAL_SECONDS=5

# 单次后台可达性探测超时秒数。建议保持较短，避免网络抖动拖住探测循环。
LLM_REACHABILITY_TIMEOUT_SECONDS=1.5

# 在线模型会话中途不可用时的播报文本，播报后结束本轮会话并等待下一次唤醒。
NETWORK_UNAVAILABLE_RESPONSE=网络连接不可用

# 大模型返回空内容时的兜底播报文本。
EMPTY_ANSWER_RESPONSE=我暂时没有生成有效回答。

# speech 从 gateway 缓存同步本轮模型选择的间隔秒数。唤醒后只读取 speech 内存缓存。
LLM_ROUTE_CACHE_INTERVAL_SECONDS=2

# 本地 Ollama 模型名。唤醒时缓存显示在线不可用时，本轮会话固定使用这个模型。
OLLAMA_MODEL=qwen3:4b-instruct

# 内部 Ollama 服务地址。compose 默认值通常不需要修改。
OLLAMA_BASE_URL=http://ollama:11434

# Ollama 上下文长度。
OLLAMA_NUM_CTX=2048

# Ollama CPU 线程数。
OLLAMA_NUM_THREAD=8

# 唤醒词 KWS 模型名。对应 data/models/<模型名>，通常不改。
VOICE_KWS_MODEL_NAME=sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20

# 唤醒词 KWS 模型压缩包下载地址。换 KWS 模型时需要和模型名一起改。
VOICE_KWS_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/kws-models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20.tar.bz2

# ASR 语音识别模型名。对应 data/models/<模型名>，通常不改。
VOICE_ASR_MODEL_NAME=sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20

# ASR 语音识别模型压缩包下载地址。换 ASR 模型时需要和模型名一起改。
VOICE_ASR_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20.tar.bz2

# Piper TTS 模型名。对应 data/models/piper/<模型名>，通常不改。
VOICE_PIPER_MODEL_NAME=zh_CN-huayan-medium

# Piper ONNX 模型下载地址。换 Piper 模型时需要和模型名一起改。
VOICE_PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx

# Piper JSON 配置下载地址。换 Piper 模型时需要和模型名一起改。
VOICE_PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx.json

# 逗号分隔的唤醒词。重启 chat2m-wake 后会重新生成唤醒词中间文件并生效。
WAKE_WORDS=嗨小江,嘿小江,小江

# 唤醒词得分权重。越高越偏向命中配置的唤醒词。
KWS_KEYWORDS_SCORE=1.5

# 唤醒词阈值。越高误唤醒越少，但也更容易漏唤醒。
KWS_KEYWORDS_THRESHOLD=0.25

# KWS 唤醒模型使用的 CPU 线程数。
KWS_THREADS=1

# ASR 语音识别模型使用的 CPU 线程数。
ASR_THREADS=2

# ASR 模型精度。fp32 准确率优先；int8 速度和内存占用优先。
ASR_MODEL_PRECISION=fp32

# ASR 解码方式。modified_beam_search 通常比 greedy_search 更稳，CPU 占用更高。
ASR_DECODING_METHOD=modified_beam_search

# beam search 活跃路径数量，越大越稳但越慢；仅 modified_beam_search 使用。
ASR_MAX_ACTIVE_PATHS=8

# ASR token 建模方式。当前中英混合 zipformer 模型使用 cjkchar+bpe 可支持中文热词。
ASR_MODELING_UNIT=cjkchar+bpe

# 逗号分隔的 ASR 热词，只影响识别偏置，不会生成固定回答。
ASR_HOTWORDS=十六进制,一百二十八,哪一边,哪边,哪个方向,什么方向,多少

# ASR 热词偏置分数。越高越容易识别成热词，过高可能误吸附相近发音。
ASR_HOTWORDS_SCORE=2.0

# 麦克风输入设备选择器，可以是设备序号，也可以是设备名的一部分。
AUDIO_INPUT_DEVICE=ReSpeaker

# aplay 使用的音频输出设备。
AUDIO_OUTPUT_DEVICE=plughw:CARD=ArrayUAC10,DEV=0

# 打开麦克风时使用的输入声道数。
AUDIO_INPUT_CHANNELS=1

# 多声道输入时实际取用的声道序号，从 0 开始；设为 auto 会按每个音频块选择 RMS 最大的声道。
AUDIO_INPUT_CHANNEL_INDEX=0

# KWS 和 ASR 使用的音频采样率。
AUDIO_SAMPLE_RATE=16000

# KWS/ASR 每次读取音频的块长度秒数。
AUDIO_CHUNK_SECONDS=0.1

# ReSpeaker Mic Array v3.0 控制接口。开启后 speech 会读取 DOA/VAD，并按下面参数配置板载 DSP。
RESPEAKER_ENABLED=1

# ReSpeaker 官方 USB vendor/product id。通常不需要改。
RESPEAKER_USB_VENDOR_ID=0x2886
RESPEAKER_USB_PRODUCT_ID=0x0018

# 是否在 speech 启动时写入 ReSpeaker 板载 DSP 参数。
RESPEAKER_TUNING_ENABLED=1

# ReSpeaker 自动增益控制。
RESPEAKER_AGC_ENABLED=1

# ReSpeaker 面向 ASR 的稳态噪声抑制。
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION=1

# ReSpeaker 面向 ASR 的非稳态噪声抑制。
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION=1

# 稳态噪声抑制强度，官方参数范围 0-3。
RESPEAKER_ASR_STATIONARY_NOISE_SUPPRESSION_LEVEL=2.0

# 非稳态噪声抑制强度，官方参数范围 0-3。
RESPEAKER_ASR_NONSTATIONARY_NOISE_SUPPRESSION_LEVEL=2.0

# ReSpeaker VAD 阈值，单位 dB。
RESPEAKER_VAD_THRESHOLD_DB=3.5

# ReSpeaker 回声抑制。输出不走 ReSpeaker 播放通道时建议保持关闭。
RESPEAKER_ECHO_SUPPRESSION_ENABLED=0

# ReSpeaker 非线性 AEC。输出不走 ReSpeaker 播放通道时建议保持关闭。
RESPEAKER_NONLINEAR_AEC_ENABLED=0

# DOA 角度校准：设备正前方对应的原始角度。
RESPEAKER_DOA_FRONT_OFFSET_DEGREES=0

# DOA 角度方向。1 表示角度顺时针增加；如果左右回答相反，改成 0。
RESPEAKER_DOA_CLOCKWISE=1

# 发送给 gateway 的单次对话请求超时秒数。
GATEWAY_REQUEST_TIMEOUT_SECONDS=60

# gateway 不可用时的播报文本。
GATEWAY_UNAVAILABLE_RESPONSE=对话服务暂时不可用

# ASR 识别异常时的播报文本。
ASR_ERROR_RESPONSE=语音识别出错

# 唤醒后等待一句指令的最长秒数。
COMMAND_TIMEOUT_SECONDS=10

# 每次指令监听的最短秒数，避免过早结束。
COMMAND_MIN_SECONDS=1.8

# 开始监听后允许的前置静音秒数，超时还没说话就结束本轮。
COMMAND_LEADING_SILENCE_SECONDS=4

# 初始宽限秒数，在这段时间内不会因为端点检测而提前停止。
COMMAND_INITIAL_GRACE_SECONDS=1.2

# 判断“已经开始说话”的 RMS 音量阈值。
SPEECH_RMS_THRESHOLD=0.006

# ASR 前置噪声门控。开启后会先估计环境底噪，只把超过动态门限的语音送入 ASR。
ASR_NOISE_GATE_ENABLED=1

# ASR 开始监听时用于估计环境底噪的秒数。越大越稳，但会轻微增加开始监听延迟。
ASR_NOISE_CALIBRATION_SECONDS=0.2

# 底噪估计使用的 RMS 百分位，嘈杂场景建议先保持低值，避免把近场人声当作底噪。
ASR_NOISE_GATE_PERCENTILE=30

# 动态门限倍率：门限 = max(SPEECH_RMS_THRESHOLD, 底噪 * 倍率 + 偏移)。
ASR_NOISE_GATE_RATIO=0.3

# 动态门限偏移，环境底噪较低时用于避免轻微噪声进 ASR。
ASR_NOISE_GATE_OFFSET=0.006

# 语音触发时补送给 ASR 的前置音频秒数，避免吃掉句首。
ASR_PREROLL_SECONDS=0.3

# ASR endpoint rule1：较长尾部静音秒数，影响停顿后结束识别的时机。
ASR_RULE1_MIN_TRAILING_SILENCE=1.8

# ASR endpoint rule2：较短尾部静音秒数，影响已有语音后的快速收尾。
ASR_RULE2_MIN_TRAILING_SILENCE=1.2

# ASR endpoint rule3：单句最长识别长度秒数兜底。
ASR_RULE3_MIN_UTTERANCE_LENGTH=8

# 播放提示音前丢弃麦克风缓存的秒数。
PRE_BEEP_DRAIN_SECONDS=0.05

# 播放提示音后丢弃麦克风缓存的秒数。
POST_BEEP_DRAIN_SECONDS=0.05

# TTS 播放后丢弃麦克风缓存的秒数。
POST_RESPONSE_DRAIN_SECONDS=0.5

# wake 等待 speech 在线时，重复日志的间隔秒数。
SPEECH_WAIT_LOG_SECONDS=30

# wake 等待 speech/status 状态变化时的轮询间隔秒数。
SPEECH_WAIT_POLL_SECONDS=1

# 唤醒后立即播报的回复。
WAKE_RESPONSE=有什么可以帮助您的

# 单体 agent 模式没听到指令时播报的回复。
NO_COMMAND_RESPONSE=请再说一遍

# 没听到指令时播报的回复。留空表示不播报。
SESSION_IDLE_RESPONSE=

# 会话结束或达到最大轮数时播报的回复。
SESSION_END_RESPONSE=好的，我先待机

# 这些短语会结束当前会话，逗号分隔。
SESSION_END_PHRASES=退出,结束,不用了,没事了,再见,拜拜,回到待机,退下,退下吧,你走吧,走吧,下去吧,可以了,先这样

# 一次唤醒后的最大连续对话轮数。
MAX_SESSION_TURNS=8

# Piper 说话人 ID。
PIPER_SPEAKER=0

# Piper 语速控制。越小越慢，越大越快。
PIPER_LENGTH_SCALE=0.9

# Piper 噪声参数。
PIPER_NOISE_SCALE=0.667

# Piper 噪声宽度参数。
PIPER_NOISE_W_SCALE=0.8

# Piper 输出音量倍率。
PIPER_VOLUME=1.0

# TTS 播放进程最长等待秒数。
TTS_PLAYER_TIMEOUT_SECONDS=30

# 状态屏串口。默认使用宿主机 udev 规则创建的稳定设备名，避免绑定 /dev/ttyACM0 这类会漂移的 USB 口。
DISPLAY_SERIAL_PORT=/dev/chat2m-display

# 状态屏串口候选列表。通常留空；DISPLAY_SERIAL_PORT=auto 时才会使用。
DISPLAY_SERIAL_CANDIDATES=

# 状态屏串口波特率。
DISPLAY_SERIAL_BAUD=115200

# 状态屏当前状态重发间隔秒数。用于避免串口偶发丢帧导致屏幕停在旧状态；设为 0 可关闭。
DISPLAY_SYNC_SECONDS=1.0

# 状态屏显示文本最大字符数。
DISPLAY_TEXT_MAX_CHARS=80

# 状态屏串口写入失败后的重试冷却秒数。
DISPLAY_SERIAL_RETRY_SECONDS=5

# status /wait 接口允许的最长等待秒数。
STATUS_WAIT_MAX_TIMEOUT_SECONDS=86400

# 等待模型下载锁时，重复日志的间隔秒数。
LOCK_WAIT_LOG_SECONDS=30
