# Chat2M runtime.env 配置参考
# 实际运行请修改 /opt/chat2m/data/config/runtime.env。
# 这里列的是建议对外开放的运行参数；容器内部路径和服务地址不作为用户配置项。

# 对话使用、校验和自动拉取的 Ollama 模型名。
OLLAMA_MODEL=qwen3:4b-instruct

# 唤醒词 KWS 模型名。对应 data/models/<模型名>，通常不改。
VOICE_KWS_MODEL_NAME=sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20

# 唤醒词 KWS 模型压缩包下载地址。换 KWS 模型时需要和模型名一起改。
VOICE_KWS_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/kws-models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20.tar.bz2

# ASR 语音识别模型名。对应 data/models/<模型名>，通常不改。
VOICE_ASR_MODEL_NAME=sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20

# ASR 语音识别模型压缩包下载地址。换 ASR 模型时需要和模型名一起改。
VOICE_ASR_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20.tar.bz2

# Piper TTS 模型名。对应 data/models/piper/<模型名>，通常不改。
VOICE_PIPER_MODEL_NAME=zh_CN-huayan-medium

# Piper ONNX 模型下载地址。换 Piper 模型时需要和模型名一起改。
VOICE_PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx

# Piper JSON 配置下载地址。换 Piper 模型时需要和模型名一起改。
VOICE_PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx.json

# 逗号分隔的唤醒词。重启 chat2m-wake 后会重新生成唤醒词中间文件并生效。
WAKE_WORDS=嗨小江,嘿小江,小江

# 唤醒词得分权重。越高越偏向命中配置的唤醒词。
KWS_KEYWORDS_SCORE=1.5

# 唤醒词阈值。越高误唤醒越少，但也更容易漏唤醒。
KWS_KEYWORDS_THRESHOLD=0.25

# KWS 唤醒模型使用的 CPU 线程数。
KWS_THREADS=1

# ASR 语音识别模型使用的 CPU 线程数。
ASR_THREADS=2

# 麦克风输入设备选择器，可以是设备序号，也可以是设备名的一部分。
AUDIO_INPUT_DEVICE=ReSpeaker

# aplay 使用的音频输出设备。
AUDIO_OUTPUT_DEVICE=plughw:CARD=ArrayUAC10,DEV=0

# 打开麦克风时使用的输入声道数。
AUDIO_INPUT_CHANNELS=1

# 多声道输入时实际取用的声道序号，从 0 开始。
AUDIO_INPUT_CHANNEL_INDEX=0

# KWS 和 ASR 使用的音频采样率。
AUDIO_SAMPLE_RATE=16000

# 唤醒后等待一句指令的最长秒数。
COMMAND_TIMEOUT_SECONDS=10

# 每次指令监听的最短秒数，避免过早结束。
COMMAND_MIN_SECONDS=1.8

# 开始监听后允许的前置静音秒数，超时还没说话就结束本轮。
COMMAND_LEADING_SILENCE_SECONDS=4

# 初始宽限秒数，在这段时间内不会因为端点检测而提前停止。
COMMAND_INITIAL_GRACE_SECONDS=1.2

# 判断“已经开始说话”的 RMS 音量阈值。
SPEECH_RMS_THRESHOLD=0.006

# 播放提示音前丢弃麦克风缓存的秒数。
PRE_BEEP_DRAIN_SECONDS=0.05

# 播放提示音后丢弃麦克风缓存的秒数。
POST_BEEP_DRAIN_SECONDS=0.05

# TTS 播放后丢弃麦克风缓存的秒数。
POST_RESPONSE_DRAIN_SECONDS=0.5

# wake 等待 speech 在线时，重复日志的间隔秒数。
SPEECH_WAIT_LOG_SECONDS=30

# 唤醒后立即播报的回复。
WAKE_RESPONSE=有什么可以帮助您的

# 没听到指令时播报的回复。留空表示不播报。
SESSION_IDLE_RESPONSE=

# 会话结束或达到最大轮数时播报的回复。
SESSION_END_RESPONSE=好的，我先待机

# 这些短语会结束当前会话，逗号分隔。
SESSION_END_PHRASES=退出,结束,不用了,没事了,再见,拜拜,回到待机,退下,退下吧,你走吧,走吧,下去吧,可以了,先这样

# 一次唤醒后的最大连续对话轮数。
MAX_SESSION_TURNS=8

# Piper 说话人 ID。
PIPER_SPEAKER=0

# Piper 语速控制。越小越慢，越大越快。
PIPER_LENGTH_SCALE=0.9

# Piper 噪声参数。
PIPER_NOISE_SCALE=0.667

# Piper 噪声宽度参数。
PIPER_NOISE_W_SCALE=0.8

# Piper 输出音量倍率。
PIPER_VOLUME=1.0

# 状态屏串口。auto 表示从 DISPLAY_SERIAL_CANDIDATES 自动选择。
DISPLAY_SERIAL_PORT=auto

# 状态屏串口候选列表，逗号分隔。
DISPLAY_SERIAL_CANDIDATES=/dev/ttyACM0,/dev/ttyACM1,/dev/ttyUSB0,/dev/ttyUSB1,/host-dev/ttyACM0,/host-dev/ttyACM1,/host-dev/ttyUSB0,/host-dev/ttyUSB1

# 状态屏串口波特率。
DISPLAY_SERIAL_BAUD=115200

# 等待模型下载锁时，重复日志的间隔秒数。
LOCK_WAIT_LOG_SECONDS=30
